<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="314.0" prefWidth="314.0" spacing="10.0" style="-fx-background-color: #1f1d2b; -fx-background-radius: 24px;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.components.ReservaItemController">
   <children>
      <HBox prefHeight="82.0" prefWidth="282.0">
