                     <image>
                        <Image url="@../images/users.png" />
                     </image>
                  </ImageView>
                  <Label fx:id="lbPessoas" prefHeight="40.0" prefWidth="173.0" text="6 pessoas" textFill="#abbbc2">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
      <Button fx:id="btnCancelar" mnemonicParsing="false" prefHeight="34.0" prefWidth="346.0" styleClass="removerBtn" stylesheets="@../css/fazerpedido.css" text="Cancelar Reserva" />
