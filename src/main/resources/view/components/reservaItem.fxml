            <Label fx:id="lbMesaNr" alignment="TOP_CENTER" prefHeight="70.0" prefWidth="68.0" style="-fx-background-color: #ffa300; -fx-background-radius: 18px;" text="4" textAlignment="CENTER" textFill="#1f1d2b">
               <font>
                  <Font name="Raleway Bold" size="36.0" />
               </font>
            </Label>
            <HBox alignment="CENTER_RIGHT" prefHeight="72.0" prefWidth="208.0">
