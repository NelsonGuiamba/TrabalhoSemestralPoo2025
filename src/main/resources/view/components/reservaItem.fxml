                  <Label fx:id="lbMesaNome" alignment="BOTTOM_CENTER" prefHeight="24.0" prefWidth="79.0" style="-fx-background-color: rgba(255, 163, 0, 0.15); -fx-background-radius: 50px;" text="Mesa 4" textFill="#ffa100">
                     <font>
                        <Font name="Montserrat Regular" size="18.0" />
                     </font>
                     <padding>
                        <Insets bottom="3.0" left="3.0" right="3.0" top="3.0" />
                     </padding>
                  </Label>
               </children>
            </HBox>
         </children>
      </HBox>
      <VBox prefHeight="200.0" prefWidth="100.0" spacing="15.0">
