<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox prefHeight="720" prefWidth="1256" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    
    <VBox prefWidth="240" spacing="25" style="-fx-background-color: #1f1d2b;">
        <padding>
            <Insets bottom="30" left="20" right="20" top="30" />
        </padding>
        <Label style="-fx-text-fill: #ffa300; -fx-font-size: 20px; -fx-font-weight: bold;" text="ADMIN DASHBOARD">
         <font>
            <Font name="Montserrat Bold" size="12.0" />
         </font></Label>
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Mesas" />
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Pedidos" />
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Reservas" />
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Menu" />
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Usuários" />
        <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #abbbc2; -fx-font-size: 16px;" text="Relatórios" />
    </VBox>

    
    <VBox spacing="25" style="-fx-background-color: #252836;" HBox.hgrow="ALWAYS">
        <padding>
            <Insets bottom="25" left="25" right="25" top="25" />
        </padding>

        <Label style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;" text="Bem-vindo, Administrador" />

        <TabPane tabClosingPolicy="UNAVAILABLE" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">


            <Tab text="Mesas">
                <TableView fx:id="tableMesas" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="100" text="ID" />
                        <TableColumn prefWidth="150" text="Capacidade" />
                        <TableColumn prefWidth="200" text="Status" />
                    </columns>
                </TableView>
            </Tab>

            
            <Tab text="Pedidos">
                <TableView fx:id="tablePedidos" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80" text="ID" />
                        <TableColumn prefWidth="200" text="Cliente" />
                        <TableColumn prefWidth="120" text="Mesa" />
                        <TableColumn prefWidth="150" text="Status" />
                        <TableColumn prefWidth="200" text="Data" />
                    </columns>
                </TableView>
            </Tab>

            
            <Tab text="Reservas">
                <TableView fx:id="tableReservas" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80" text="ID" />
                        <TableColumn prefWidth="200" text="Cliente" />
                        <TableColumn prefWidth="120" text="Mesa" />
                        <TableColumn prefWidth="200" text="Data Início" />
                        <TableColumn prefWidth="200" text="Data Fim" />
                        <TableColumn prefWidth="150" text="Status" />
                    </columns>
                </TableView>
            </Tab>

            
            <Tab text="Menu">
                <TableView fx:id="tableMenu" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80" text="ID" />
                        <TableColumn prefWidth="250" text="Nome" />
                        <TableColumn prefWidth="200" text="Categoria" />
                        <TableColumn prefWidth="150" text="Preço" />
                    </columns>
                </TableView>
            </Tab>


            <Tab text="Usuários">
                <TableView fx:id="tableUsuarios" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="80" text="ID" />
                        <TableColumn prefWidth="250" text="Nome" />
                        <TableColumn prefWidth="300" text="Email" />
                        <TableColumn prefWidth="150" text="Tipo" />
                    </columns>
                </TableView>
            </Tab>


            <Tab text="Relatórios">
                <TableView fx:id="tableRelatorios" prefHeight="600" prefWidth="1000" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn prefWidth="400" text="Descrição" />
                        <TableColumn prefWidth="150" text="Valor" />
                        <TableColumn prefWidth="200" text="Data" />
                    </columns>
                </TableView>
            </Tab>

        </TabPane>
    </VBox>

</HBox>
